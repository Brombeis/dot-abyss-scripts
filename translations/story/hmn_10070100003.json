    },
    {
      "line": 472,
      "cmd": "message",
      "field": 2,
      "name": "フィルム",
      "jp": "し、司令官くん、わたしを庇ってくれたの！？",
      "en": ""
    },
    {
      "line": 474,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "あんまり気を抜くな、<br>怪我をするところだったぞ！",
