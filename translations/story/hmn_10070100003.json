      "en": ""
    },
    {
      "line": 268,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "くっ、今度こそ本物か！<br>この規模の大きさ、原因はまさか……",
      "en": ""
    },
    {
      "line": 279,
      "cmd": "message",
      "field": 2,
      "name": "フィルム",
