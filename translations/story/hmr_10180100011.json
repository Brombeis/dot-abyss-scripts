      "en": ""
    },
    {
      "line": 157,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "（マジか……ここまでされても無反応とは……<br>なんだかこっちも意地になってきたな……）",
      "en": ""
    },
    {
