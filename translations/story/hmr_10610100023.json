  "lines": [
    {
      "line": 38,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "お忘れ物はございませんか？",
      "en": ""
    },
    {
      "line": 40,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "服を着直し、部屋を出る準備をした男にニナがそう問いかけると、<br>男は１度頷いてから、ハッと何かを思い出したような素振りを見せた。",
      "en": ""
    },
    {
      "line": 79,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "それから男は、テーブルの上に置いてあったティーカップを手に取る。",
      "en": ""
    },
    {
      "line": 113,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "あ……お茶をご所望でしたら、すぐに温かいものを入れ直して――",
      "en": ""
    },
    {
      "line": 115,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ニナにみなまで言わさず、男は冷めたハーブティーを一気に飲み干した。",
      "en": ""
    },
    {
      "line": 123,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "呆気にとられるニナだったが、すぐにまた笑顔になり――",
      "en": ""
    },
    {
      "line": 142,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "またいらしてくださいね？",
      "en": ""
    },
    {
      "line": 144,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "しかし、男は静かに首を横に振った。",
      "en": ""
    },
    {
      "line": 155,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "え……門番の仕事を辞めて、故郷へ戻られるのですか？",
      "en": ""
    },
    {
      "line": 157,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "男は、ニナの入れてくれたハーブティーが、忘れようとしていた家族の笑顔と<br>故郷を思い出させてくれたと伝える。",
      "en": ""
    },
    {
      "line": 159,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "そして、故郷に戻って、もう１度ハーブを育てる仕事を再開したいと――",
      "en": ""
    },
    {
      "line": 171,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "そう、ですか……それが、貴方様の決めたことでしたら……<br>わたくしは応援します。頑張ってください。",
      "en": ""
    },
    {
      "line": 173,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "男はニナに感謝の言葉と、ハーブが採れたらニナ宛てに送ることを伝える。",
      "en": ""
    },
    {
      "line": 184,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "はい、その日を楽しみにしています。<br>どうかお元気で。",
      "en": ""
    },
    {
      "line": 196,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ニナとの出会いが、疲れた男の背中を押すきっかけになったことは間違いない。<br>部屋を出ていく男の姿を、ニナは優しい微笑みで見送った。",
      "en": ""
    }
  ]
}
