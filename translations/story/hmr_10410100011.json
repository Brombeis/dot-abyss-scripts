    },
    {
      "line": 22,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "<user>の待つ司令室に<br>１人の女性が姿を見せた。",
      "en": ""
    },
    {
      "line": 31,
      "cmd": "message",
      "field": 2,
      "name": "アヤメ",
      "jp": "お呼びですか、司令官様。<br>アヤメが参りました。",
      "en": ""
    },
    {
      "line": 33,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "ああ、来てくれたか。<br>少しアヤメに聞きたいことがあってな。",
      "en": ""
    },
    {
      "line": 42,
      "cmd": "message",
      "field": 2,
      "name": "アヤメ",
      "jp": "私に聞きたいこと、ですか。<br>どうぞどうぞ、なんでもお話しますよ？",
      "en": ""
    },
    {
      "line": 44,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "アヤメ、お前はここに来るまで、<br>殺し屋をしていたんだよな。",
      "en": ""
    },
    {
      "line": 54,
      "cmd": "message",
      "field": 2,
      "name": "アヤメ",
      "jp": "はい、雇い主からのご命令通りに、<br>どんな相手でも殺してまいりました。",
      "en": ""
    },
    {
      "line": 56,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "……殺し以外の依頼は受けたことがあるのか？",
      "en": ""
    },
    {
      "line": 65,
      "cmd": "message",
      "field": 2,
      "name": "アヤメ",
      "jp": "いいえ、ありませんが……。<br>何かご依頼したいことがあるのですか？",
      "en": ""
    },
    {
      "line": 67,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "ああ……お前には人を傷つける仕事ではなく、<br>愉しませる仕事をしてもらいたいと思ってな。",
      "en": ""
    },
    {
      "line": 69,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "どうだ、受けてくれるか？",
      "en": ""
    },
    {
      "line": 79,
      "cmd": "message",
      "field": 2,
      "name": "アヤメ",
      "jp": "はい、司令官様のご命令であれば、<br>どんな依頼でも喜んでお受けいたしますよ。",
      "en": ""
    }
