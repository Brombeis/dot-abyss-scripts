      "en": ""
    },
    {
      "line": 47,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "違うのか？　じゃあ、お返しというのは？",
      "en": ""
    },
    {
      "line": 58,
      "cmd": "message",
      "field": 2,
      "name": "ラヴェリア",
      "jp": "今日は、その……。<br>アタシが兄さんを気持ちよくしてあげたいんだ。",
      "en": ""
