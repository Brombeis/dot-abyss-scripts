  "lines": [
    {
      "line": 19,
      "cmd": "title",
      "field": 1,
      "name": "",
      "jp": "妖艶なる戯れ",
      "en": ""
    },
    {
      "line": 48,
      "cmd": "message",
      "field": 2,
      "name": "ウィステリア",
      "jp": "娼館での仕事など、私には不向きだと思っていたが……<br>やってみればなんとかなるものだな。",
      "en": ""
    },
    {
      "line": 50,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "人で賑わう酒場の影、ウィステリアはどこか自慢げに呟いていた。<br>誰も、彼女の存在に気付いている様子はない。",
      "en": ""
    },
    {
      "line": 52,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "<user>との行為以来、彼女もまた娼館で働くように<br>なっていたのだが、娼婦としてかなりの人気を得ているのだ。",
      "en": ""
    },
    {
      "line": 64,
      "cmd": "message",
      "field": 2,
      "name": "ウィステリア",
      "jp": "客と自然に会話をしようとすると、やはり上手くいかないが……<br>まあ、潜入調査で娼婦を演じていると思えばなんとでもなるな。",
      "en": ""
    },
    {
      "line": 81,
      "cmd": "message",
      "field": 2,
      "name": "ウィステリア",
      "jp": "……しかし、誰も私だと気づかないとはな。<br>普段からあまり人前に出てないせいか。まあ、その方が都合はいいが。",
      "en": ""
    },
    {
      "line": 83,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "情事の最中に”戦神”などと呼ばれれば、互いに興ざめだろう。<br>そんなことを考えていた、その時だった。",
      "en": ""
    },
    {
      "line": 106,
      "cmd": "message",
      "field": 2,
      "name": "娼館客",
      "jp": "――へえ、いろんな子がいるんですね。",
      "en": ""
    },
    {
      "line": 144,
      "cmd": "message",
      "field": 2,
      "name": "ウィステリア",
      "jp": "……ん？　今の声は……",
      "en": ""
    },
    {
      "line": 176,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "聞き覚えのある声に影から様子をうかがうと、<br>同じ部隊の同僚がルディアの接客を受けていた。",
      "en": ""
    },
    {
      "line": 178,
      "cmd": "message",
      "field": 2,
      "name": "ウィステリア",
      "jp": "あの男は……",
      "en": ""
    },
    {
      "line": 180,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "森に潜んでいたウィステリアに気づかず彼女と行為をおこなった同僚――<br>まさしく、ウィステリアが卑猥な夢を見るようになった原因の男だった。",
      "en": ""
    },
    {
      "line": 191,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "この子はいかがですか？　とっても人気の子ですよ。<br>１回この子を指名すると、皆さんこの子しか指名しなくなるんです。",
      "en": ""
    },
    {
      "line": 193,
      "cmd": "message",
      "field": 2,
      "name": "娼館客",
      "jp": "うわあ……めちゃくちゃいいですね。<br>うちの隊にいる、綺麗な子に似てるかも……",
      "en": ""
    },
    {
      "line": 195,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "じゃあこの子で！　と男が指名する。<br>笑顔で頷いたルディアは、そっとウィステリアに歩み寄った。",
      "en": ""
    },
    {
      "line": 259,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "ご指名よ、ウィステリアさん。",
      "en": ""
    },
    {
      "line": 270,
      "cmd": "message",
      "field": 2,
      "name": "ウィステリア",
      "jp": "ん……相手は私、か……。<br>もしも彼が気づいていないなら……",
      "en": ""
    },
    {
      "line": 320,
      "cmd": "message",
      "field": 2,
      "name": "ウィステリア",
      "jp": "……ちょうどいい。<br>少し、試してみようか。",
      "en": ""
    },
    {
      "line": 322,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "まるで狩りに出かけた時のように、<br>密やかな声で、ウィステリアは呟いたのだった。",
      "en": ""
    }
  ]
}