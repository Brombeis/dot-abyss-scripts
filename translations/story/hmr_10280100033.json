  "lines": [
    {
      "line": 17,
      "cmd": "messageTextCenter",
      "field": 2,
      "name": "",
      "jp": "<size=48>数日後――</size>",
      "en": ""
    },
    {
      "line": 32,
      "cmd": "message",
      "field": 2,
      "name": "エミリー",
      "jp": "あ、しれーかん！　たいへんたいへんです！",
      "en": ""
    },
    {
      "line": 34,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "そんなに慌ててどうしたんだ？",
      "en": ""
    },
    {
      "line": 41,
      "cmd": "message",
      "field": 2,
      "name": "エミリー",
      "jp": "ほら、あそこ。<br>……あの日、酔い潰れてたお客さん。",
      "en": ""
    },
    {
      "line": 43,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "エミリーがこっそり指差した席で仲間と飲んでいるのは、<br>たしかにあの夜、酔い潰れていた客だ。",
      "en": ""
    },
    {
      "line": 45,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "聞き耳を立てていると、どうやらこの前この店ですげーエロい光景を見た<br>という話で盛り上がっている。",
      "en": ""
    },
    {
      "line": 47,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "曰く、ウエイトレスの子が、この机の上でデカマラの男に突かれてたと……",
      "en": ""
    },
    {
      "line": 52,
      "cmd": "message",
      "field": 2,
      "name": "エミリー",
      "jp": "やっぱりあの日のことバレてたんですよぉ、どうしよう……",
      "en": ""
    },
    {
      "line": 54,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "だがさらに聞いていると、男は実は夢の話なんだけどなというオチを付けて、<br>仲間の笑いを誘っていた。",
      "en": ""
    },
    {
      "line": 62,
      "cmd": "message",
      "field": 2,
      "name": "エミリー",
      "jp": "夢の話！？　はぁ、よかったぁ～……<br>え？　しれーかん、どうして笑っているんですか？",
      "en": ""
    },
    {
      "line": 64,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "もしかして、この俺があの客が起きるかもしれない状況で<br>行為におよんだと本気で思っているのか？",
      "en": ""
    },
    {
      "line": 71,
      "cmd": "message",
      "field": 2,
      "name": "エミリー",
      "jp": "どういう意味です？",
      "en": ""
    },
    {
      "line": 73,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "あの客の飲んでいた酒からは僅かだが煎じた眠り草の匂いがした。",
      "en": ""
    },
    {
      "line": 81,
      "cmd": "message",
      "field": 2,
      "name": "エミリー",
      "jp": "眠り草？",
      "en": ""
    },
    {
      "line": 83,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "あの客は、眠れないことをルディアに相談していたって言ってたよな？",
      "en": ""
    },
    {
      "line": 85,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "そして客の身を案じたルディアは<br>眠り草を煎じた酒を客に提供した。",
      "en": ""
    },
    {
      "line": 87,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "そうなんだろ？　ルディア。",
      "en": ""
    },
    {
      "line": 106,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "どこからともなく現れるルディア。",
      "en": ""
    },
    {
      "line": 114,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "ああ、それなら<br>司令官君が店に来た時にはとっくに効果は切れていたはずよ？",
      "en": ""
    },
    {
      "line": 124,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "え！？",
      "en": ""
    },
    {
      "line": 131,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "だって、いつまでも寝てられたら店が閉められないでしょ。<br>そのくらいちゃんと計算して出してるわよ。",
      "en": ""
    },
    {
      "line": 133,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "じょ、冗談だよな？",
      "en": ""
    },
    {
      "line": 146,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "ふふ、さあどうでしょうね～？<br>あなたたちこそ、お客様が寝てると思って何をしてたんです？",
      "en": ""
    },
    {
      "line": 149,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "冷やかすように訊かれ、エミリーと２人で冷や汗をかくのだった。",
      "en": ""
    }
  ]
}