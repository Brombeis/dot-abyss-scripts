    {
      "line": 26,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "目が覚めると、すぐそばにダリアの寝顔があった。<br>どこか心地よさそうな表情が可愛くて、そのまま見続けてしまう。",
      "en": ""
    },
    {
      "line": 39,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "（しかし……普段はクールなダリアが、<br>あんなに情熱的になるなんてな……）",
      "en": ""
    },
    {
      "line": 52,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "すると、ぱちっとダリアが目覚めた。",
      "en": ""
    },
    {
      "line": 63,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "起きたか。おはよう。",
      "en": ""
    },
    {
      "line": 73,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "……はい。おはようございます。",
      "en": ""
    },
    {
      "line": 75,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "口調が元通りになったな――そんなことを思っていると、<br>彼女が色っぽい表情で問い掛けてきた。",
      "en": ""
    },
    {
      "line": 84,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "親方……このまま、もう１回研修したいです。",
      "en": ""
    },
    {
      "line": 86,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "予想を裏切る甘い声での懇願に、思わず笑みを浮かべてしまうのだった。",
      "en": ""
    }
  ]
