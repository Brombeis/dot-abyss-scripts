  "lines": [
    {
      "line": 17,
      "cmd": "title",
      "field": 1,
      "name": "",
      "jp": "悪戯はやめてください御主人様",
      "en": ""
    },
    {
      "line": 27,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "きぃやぁ～～～～～～～～～～っ！？",
      "en": ""
    },
    {
      "line": 37,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "司令室にニナの悲鳴が響き渡る。",
      "en": ""
    },
    {
      "line": 70,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "む、むむむ虫ぃっ……！？<br>ご、御主人様ぁっ！　虫っ、虫ですっ！　芋虫が窓にぃっ！",
      "en": ""
    },
    {
      "line": 88,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "窓掃除をしていたニナが、バックステップで窓から距離をとると、<br>素早い身のこなしで戦闘態勢に入る。",
      "en": ""
    },
    {
      "line": 90,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "っ……ぷ……ぷぷっ！<br>くはっ！　あはははは！",
      "en": ""
    },
    {
      "line": 92,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "予想外のリアクションで驚くニナを見て、<br>思わず声を上げて笑ってしまった。",
      "en": ""
    },
    {
      "line": 119,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "な、ななな、何がおかしいんですか！",
      "en": ""
    },
    {
      "line": 121,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "すまない、ニナ……くくっ……そいつをよく見てくれ……",
      "en": ""
    },
    {
      "line": 132,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "よ、よく見ろと言われましても……",
      "en": ""
    },
    {
      "line": 181,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "薄目を開け、いつでも逃げられるように距離を取りながら、<br>おそるおそる芋虫（？）に近付くニナ。",
      "en": ""
    },
    {
      "line": 200,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "あ……こ、これ……ただの木の枝……？<br>それを芋虫の形に似せて削ってある……だ、誰がこんなものを……",
      "en": ""
    },
    {
      "line": 202,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "悪い悪い。ニナの可愛い反応が見たくてな。<br>昨日俺が作って、そこに置いたんだ。",
      "en": ""
    },
    {
      "line": 213,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "も、もうっ！　またそんなくだらないことを考えて！<br>子どもみたいな悪戯で、お掃除の邪魔をするのはやめてください！",
      "en": ""
    },
    {
      "line": 233,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "そう言うと、ニナは頬をぷくっと膨らませ、<br>背中を向けて窓掃除に戻ってしまった。",
      "en": ""
    },
    {
      "line": 235,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "ホント、いつまでたってもやることが子どもみたい……<br>あ、ハーブティー淹れておきましたので御自由にどうぞ！",
      "en": ""
    },
    {
      "line": 237,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ブツブツと文句を言いながら窓掃除の続きを始める。<br>ニナは、普段はいたってクールで、あまり表情を変えることはなかった。",
      "en": ""
    },
    {
      "line": 239,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "それ故に、こちらとしては彼女の普段見せない表情やリアクションを見たくて、<br>ついちょっかいを出してしまいたくなるのだ。",
      "en": ""
    },
    {
      "line": 258,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "ふむ……",
      "en": ""
    },
    {
      "line": 268,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ニナが用意してくれていたハーブティーを口にする。<br>清涼感のある香りが拡がり、心が落ち着く――",
      "en": ""
    },
    {
      "line": 284,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "ん……！？",
      "en": ""
    },
    {
      "line": 286,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "なんだか、急に体中が熱くなる。<br>そして、燃えるような血流が下腹部へと流れ込んでいく――",
      "en": ""
    },
    {
      "line": 288,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "目の前には可愛いお尻を無防備に突き出したニナの姿。<br>荒くなる呼吸を押さえながら、ゆっくりと彼女の方に近付いていく。",
      "en": ""
    },
    {
      "line": 326,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "ひゃうぅっ！？",
      "en": ""
    },
    {
      "line": 328,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "気が付くと、ニナの柔らかい尻肉を触っている自分が居た。<br>体中のムラムラが抑えられない。",
      "en": ""
    },
    {
      "line": 339,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "ちょっ……御主人様！？<br>今度は何を！？",
      "en": ""
    },
    {
      "line": 341,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "だ、だめだ……ハーブティーに口を付けてから、<br>体中がムラムラして抑えが利かない……",
      "en": ""
    },
    {
      "line": 376,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "理性より先に欲情がひた走っていく。<br>彼女の尻を撫でながら、もう片方の手をニナの胸へと滑らせる。",
      "en": ""
    },
    {
      "line": 387,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "あっ、やっ……！？<br>御主人様、ダメっ！　んんっ……あぁっ！",
      "en": ""
    },
    {
      "line": 389,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "俺から逃れようとニナは慌てて身をよじらせる。<br>しかし、そのせいでバランスが崩れ――",
      "en": ""
    },
    {
      "line": 416,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "あぁんっ！！！！",
      "en": ""
    }
  ]
}