    {
      "line": 28,
      "cmd": "message",
      "field": 2,
      "name": "ルカ",
      "jp": "あっ、しれーかーんっ！",
      "en": ""
    },
    {
      "line": 46,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "あれから数日後、前線基地内でこちらを見つけたルカが、<br>全速力で駆け寄って来る。",
      "en": ""
    },
    {
      "line": 48,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ルカは周囲を見て誰もいないことを確認してから、<br>そっと耳打ちしてきた。",
      "en": ""
    },
    {
      "line": 57,
      "cmd": "message",
      "field": 2,
      "name": "ルカ",
      "jp": "ねえ、この前の娼館での勝負のことなんだけど……",
      "en": ""
    },
    {
      "line": 59,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "ん？　どうかしたのか？<br>今更、やっぱり負けは認めないってのはナシだぞ？",
      "en": ""
    },
    {
      "line": 68,
      "cmd": "message",
      "field": 2,
      "name": "ルカ",
      "jp": "リベンジマッチ……さ、させてくれないかなって思って……",
      "en": ""
    },
    {
      "line": 70,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "こないだので、もう俺の勝ちは決まったんじゃなかったのか？",
      "en": ""
    },
    {
      "line": 78,
      "cmd": "message",
      "field": 2,
      "name": "ルカ",
      "jp": "まだ終わってないよ！<br>３本勝負の内、１本取られただけだもん！",
      "en": ""
    },
    {
      "line": 80,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "は？　おいおい……いつから3本勝負になったんだよ。",
      "en": ""
    },
    {
      "line": 89,
      "cmd": "message",
      "field": 2,
      "name": "ルカ",
      "jp": "いや、やっぱり５本勝負ってことにしよう！",
      "en": ""
    },
    {
      "line": 91,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "なんで増やすんだよ！",
      "en": ""
    },
    {
      "line": 100,
      "cmd": "message",
      "field": 2,
      "name": "ルカ",
      "jp": "え～……だって、すぐ終わっちゃうの、やだもん……",
      "en": ""
    },
    {
      "line": 103,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "そう言って、ルカはモジモジと太ももを擦らせている。<br>どうやら、あの”勝負”がよっぽど気に入ったらしい。",
      "en": ""
    },
    {
      "line": 105,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "……仕方ない。<br>５本勝負だろうが１２ラウンドだろうが付き合うよ。",
      "en": ""
    },
    {
      "line": 115,
      "cmd": "message",
      "field": 2,
      "name": "ルカ",
      "jp": "ほんと？　やった～！<br>今日こそは、しれーかん倒してあたしがチャンピオンになってやるんだから！",
      "en": ""
    }
  ]
}