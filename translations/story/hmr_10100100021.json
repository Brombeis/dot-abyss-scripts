    {
      "line": 38,
      "cmd": "message",
      "field": 2,
      "name": "娼館客",
      "jp": "ありがとうディアーナ！<br>今日も最高だった……また来るね！",
      "en": ""
    },
    {
      "line": 49,
      "cmd": "message",
      "field": 2,
      "name": "ディアーナ",
      "jp": "うん♪<br>またきてね～！",
      "en": ""
    },
    {
      "line": 51,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "――笑顔で帰る利用客を送り出し、ディアーナは満足げに微笑む。<br>娼館の体験入店をして以来、彼女は娼婦として働くようになっていた。",
      "en": ""
    },
    {
      "line": 102,
      "cmd": "message",
      "field": 2,
      "name": "ディアーナ",
      "jp": "（ふふ～、さっきのお客さんも楽しかったっ！<br>感じるとこも、好きなやりかたも、人によって全然違って面白いな～♪）",
      "en": ""
    },
    {
      "line": 114,
      "cmd": "message",
      "field": 2,
      "name": "ディアーナ",
      "jp": "（ボク、この仕事がすご～く向いてるのかも♪）",
      "en": ""
    },
    {
      "line": 179,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "お疲れ様、ディアーナさん。<br>今日もすごい人気ね～？",
      "en": ""
    },
    {
      "line": 190,
      "cmd": "message",
      "field": 2,
      "name": "ディアーナ",
      "jp": "ふふ～、みんな喜んでくれてるなら、嬉しいよっ♪",
      "en": ""
    },
    {
      "line": 201,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "ええ、どのお客様も、すごく満足度が高いみたいで。<br>本当に優秀でありがたいわ～。",
      "en": ""
    },
    {
      "line": 212,
      "cmd": "message",
      "field": 2,
      "name": "ディアーナ",
      "jp": "狩りのときと同じなんだよね。よーく見ていれば、<br>獲物……じゃなくて、お客さんのどこが弱いかって、ちゃんと分かるんだ～♪",
      "en": ""
    },
    {
      "line": 223,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "ふふ、さすが狩人ね。<br>それじゃあ次のお客さんも、弱いところをついてしっかり満足させてあげてね。",
      "en": ""
    },
    {
      "line": 269,
      "cmd": "message",
      "field": 2,
      "name": "ディアーナ",
      "jp": "は～い♪<br>次の獲物はどんなかな～、ふふっ！",
      "en": ""
    },
    {
      "line": 271,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ディアーナは獲物を待ち伏せするハンターのような、<br>爛々とした瞳で客を出迎えたのだった……",
      "en": ""
    }
  ]
