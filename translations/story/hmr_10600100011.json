  "lines": [
    {
      "line": 17,
      "cmd": "title",
      "field": 1,
      "name": "",
      "jp": "ラッキースケベのその先",
      "en": ""
    },
    {
      "line": 25,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "――夜遅く。<br>司令室で仕事をしているとテルーがやってきた。",
      "en": ""
    },
    {
      "line": 69,
      "cmd": "message",
      "field": 2,
      "name": "テルー",
      "jp": "こんばんは～、司令官♪<br>あんまり無理しすぎちゃだめだよー？",
      "en": ""
    },
    {
      "line": 71,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "それはそうなんだが、今日中に片付けないといけない書類が<br>けっこうあってなぁ……",
      "en": ""
    },
    {
      "line": 82,
      "cmd": "message",
      "field": 2,
      "name": "テルー",
      "jp": "でも、ちょっとは休まなきゃ！<br>お茶持ってきたから、一緒に飲も♪",
      "en": ""
    },
    {
      "line": 84,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "……それもそうだな。一息入れるか。",
      "en": ""
    },
    {
      "line": 116,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "椅子から立ち上がると、テルーが喜んで歩み寄ってきた。<br>しかし、その拍子に――",
      "en": ""
    },
    {
      "line": 135,
      "cmd": "message",
      "field": 2,
      "name": "テルー",
      "jp": "きゃっ！",
      "en": ""
    },
    {
      "line": 137,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "危ない！",
      "en": ""
    },
    {
      "line": 174,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "躓いたテルーを慌てて抱き止める。彼女は無事だったが、<br>持っていた飲み物が彼女の胸元にこぼれてしまった",
      "en": ""
    },
    {
      "line": 185,
      "cmd": "message",
      "field": 2,
      "name": "テルー",
      "jp": "はわわわわっ……！",
      "en": ""
    },
    {
      "line": 200,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "（うっ、こ、これは――ドジっ子テルーのラッキースケベ！？）",
      "en": ""
    },
    {
      "line": 243,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "すぐに離れたが、テルーの濡れ透けた胸に目がいく。<br>疲れていたせいか、気づけばズボンを膨らませてしまった。",
      "en": ""
    },
    {
      "line": 270,
      "cmd": "message",
      "field": 2,
      "name": "テルー",
      "jp": "あっ……",
      "en": ""
    },
    {
      "line": 272,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "……あー、す、すまん。<br>これは生理現象みたいなものだ。気にするな。",
      "en": ""
    },
    {
      "line": 283,
      "cmd": "message",
      "field": 2,
      "name": "テルー",
      "jp": "う、ううん。その……嫌じゃないよ？<br>――っていうか……もしあれなら……せ、責任、取ってあげようか？",
      "en": ""
    },
    {
      "line": 285,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "……それは……そういう、意味か？",
      "en": ""
    },
    {
      "line": 294,
      "cmd": "message",
      "field": 2,
      "name": "テルー",
      "jp": "う、うん。こうなっちゃったのも、私のせいだし……<br>い、いいよ……司令官、となら――",
      "en": ""
    },
    {
      "line": 335,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "――モジモジといじらしく身体を揺らすテルー。<br>こちらも意を決して彼女の手を取り、ベッドに誘うのだった……",
      "en": ""
    }
  ]
}
