    {
      "line": 68,
      "cmd": "message",
      "field": 2,
      "name": "ベリサ",
      "jp": "ねえねえヴィーラ、これ可愛くないっ！？",
      "en": ""
    },
    {
      "line": 120,
      "cmd": "message",
      "field": 2,
      "name": "ヴィーラ",
      "jp": "ええ、とても素敵。<br>お姉ちゃんによく似合うね。",
      "en": ""
    },
    {
      "line": 131,
      "cmd": "message",
      "field": 2,
      "name": "ヴィーラ",
      "jp": "……あ、これは……",
      "en": ""
    },
    {
      "line": 173,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ヴィーラは１枚の鏡を手に取った。<br>顔がしっかりと映る、化粧をするのにちょうどいいサイズだった。",
      "en": ""
    },
    {
      "line": 182,
      "cmd": "message",
      "field": 2,
      "name": "ヴィーラ",
      "jp": "これ……買おうかな……",
      "en": ""
    },
    {
      "line": 237,
      "cmd": "message",
      "field": 2,
      "name": "ベリサ",
      "jp": "へえ、化粧鏡？<br>ヴィーラがそういうの買うなんて珍しいじゃない。",
      "en": ""
    },
    {
      "line": 294,
      "cmd": "message",
      "field": 2,
      "name": "ベリサ",
      "jp": "（ま、娼館でもちゃんと働いてるみたいだし、<br>妹だからって、いつまでも子どもじゃないのよね……）",
      "en": ""
    },
    {
      "line": 352,
      "cmd": "message",
      "field": 2,
      "name": "ヴィーラ",
      "jp": "あの……お姉ちゃん。<br>わたし、お化粧ってやったことがなくて……",
      "en": ""
    },
    {
      "line": 363,
      "cmd": "message",
      "field": 2,
      "name": "ヴィーラ",
      "jp": "やりかた、教えてくれない……？",
      "en": ""
    },
    {
      "line": 392,
      "cmd": "message",
      "field": 2,
      "name": "ベリサ",
      "jp": "……ふふっ、しょうがないわね～。<br>頼れるお姉ちゃんが教えてあげるわ♪",
      "en": ""
    },
    {
      "line": 450,
      "cmd": "message",
      "field": 2,
      "name": "ベリサ",
      "jp": "（なーんだ、やっとそーゆーことに興味が出たってだけなのね。<br>ヴィーラはやっぱり、まだまだ子どもね♪）",
      "en": ""
    },
    {
      "line": 509,
      "cmd": "message",
      "field": 2,
      "name": "ヴィーラ",
      "jp": "ありがとう、お姉ちゃん……！",
      "en": ""
    },
    {
      "line": 511,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "まだまだ子どもだ――ベリサはそう微笑んだが、<br>ヴィーラの内にあるは、恋にときめく乙女心だけではなかった。",
      "en": ""
    },
    {
      "line": 568,
      "cmd": "message",
      "field": 2,
      "name": "ヴィーラ",
      "jp": "（ちゃんとお化粧をして綺麗になれば、司令官さまが褒めてくれるかも……）",
      "en": ""
    },
    {
      "line": 579,
      "cmd": "message",
      "field": 2,
      "name": "ヴィーラ",
      "jp": "（司令官さま、喜んでくれるかな？<br>そしてまた……いっぱい、愛してくれるかな……）",
      "en": ""
    },
    {
      "line": 605,
      "cmd": "message",
      "field": 2,
      "name": "ヴィーラ",
      "jp": "……とっても、楽しみ。",
      "en": ""
    },
    {
      "line": 607,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "可愛らしい乙女心に隠れるように。<br>そこには女としての欲が、密かに顔をのぞかせていた――",
      "en": ""
    }
  ]
}