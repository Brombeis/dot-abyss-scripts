  "lines": [
    {
      "line": 17,
      "cmd": "title",
      "field": 1,
      "name": "",
      "jp": "ハーブティーが思い出させた事",
      "en": ""
    },
    {
      "line": 77,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "どうぞ……こちらをお飲みになってください。",
      "en": ""
    },
    {
      "line": 79,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ニナが差し出したティーカップと、その中に注がれたお茶の香りに、<br>娼館を訪れた客は驚いた表情を浮かべた。",
      "en": ""
    },
    {
      "line": 90,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "ハーブティーです。<br>お嫌いですか？",
      "en": ""
    },
    {
      "line": 92,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "客はしばしニナの顔をじっと見つめてから、ゆっくりと首を横に振り、<br>ティーカップを受け取ると、少し冷ましてから一口すすった。",
      "en": ""
    },
    {
      "line": 94,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "客は、前線基地の門番として働く男だった。<br>ニナが娼館で働き始めてから、何人目かの客だ。",
      "en": ""
    },
    {
      "line": 105,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "……いかがです？",
      "en": ""
    },
    {
      "line": 107,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "男は、ティーカップの中身がルイボスティーであることを言い当てた。<br>それは、男にとって故郷の味だという。",
      "en": ""
    },
    {
      "line": 118,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "そうなんですか？<br>もしよろしければ、貴方様の故郷のお話などをお聞かせいただけたらと……",
      "en": ""
    },
    {
      "line": 120,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "娼館を訪れてからほとんど口を開かない無口な男だったが、<br>懐かしい味に気持ちが和らいだのか、彼は故郷の話をポツポツと語り出した。",
      "en": ""
    },
    {
      "line": 124,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "男はかつてハーブを育てる農夫だったという。<br>しかし、男の故郷は厄災で滅び、彼は愛する家族を失ってしまった。",
      "en": ""
    },
    {
      "line": 126,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "男はそんな悲しい過去に蓋をし、故郷を離れ、遠く前線基地まで来て、<br>門番として働いていたのである。",
      "en": ""
    },
    {
      "line": 128,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "門番という仕事を選んだのも、<br>人との接触をなるべく避けるためとのことだった。",
      "en": ""
    },
    {
      "line": 139,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "そうだったのですね……そんな悲しい過去が……<br>つらい記憶を思い出させてしまい、申し訳ございませんでした。",
      "en": ""
    },
    {
      "line": 166,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ニナはそっと男の手を取ると、優しく自分の手を重ねた。",
      "en": ""
    },
    {
      "line": 175,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "今だけ……今宵だけでも、貴方様からつらい過去を忘れさせ、<br>癒してさしあげたく思います……",
      "en": ""
    },
    {
      "line": 186,
      "cmd": "message",
      "field": 2,
      "name": "ニナ",
      "jp": "どうかお気を楽に……そして、わたくしに身を委ねてくださいませ……<br>わたくしが、ご奉仕させていただきますので……",
      "en": ""
    },
    {
      "line": 219,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "そう言うと、ニナは男の手からそっとカップを取り上げ、<br>ゆっくりとベッドへと男を誘った。",
      "en": ""
    }
  ]
}
