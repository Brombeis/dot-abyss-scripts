    },
    {
      "line": 94,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "なんだ、そんなに慌てて？<br>何かあったのか？",
      "en": ""
    },
    {
      "line": 130,
      "cmd": "message",
      "field": 2,
      "name": "ホノカ",
      "jp": "いいから一緒に来て！",
      "en": ""
    },
    {
      "line": 156,
      "cmd": "message",
      "field": 2,
      "name": "",
