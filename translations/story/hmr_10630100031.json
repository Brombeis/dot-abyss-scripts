      "en": ""
    },
    {
      "line": 158,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "うわっ！？　また走るのか！？<br>俺は今日は早く帰ろうと……ちょ、ちょっと待――",
      "en": ""
    },
    {
      "line": 160,
      "cmd": "message",
      "field": 2,
      "name": "ホノカ",
      "jp": "いいから～～～～～～～～～！！",
      "en": ""
    },
    {
      "line": 192,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ホノカに引っ張ってこられたのは娼館だった。",
      "en": ""
    },
    {
      "line": 194,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "なんでこんなところに……<br>あ、もしかしてまたエッチしたくなったのか……？",
