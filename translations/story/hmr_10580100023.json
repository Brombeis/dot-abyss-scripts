    {
      "line": 56,
      "cmd": "message",
      "field": 2,
      "name": "クレハ",
      "jp": "ええ、お客様のことを旦那様だと思えば、<br>そういったことでも上手く受け入れることができましたから……",
      "en": ""
    },
    {
      "line": 60,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "そ、そうか……まあ、対応できたならよかったが……。<br>そんなやつは出禁だな、まったく。",
