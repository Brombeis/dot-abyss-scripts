    {
      "line": 18,
      "cmd": "title",
      "field": 1,
      "name": "",
      "jp": "あなたの手を取って",
      "en": ""
    },
    {
      "line": 25,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "深夜、長引いた仕事も終わろうとしていた頃。<br>最後の書類の内容が目に入った。",
      "en": ""
    },
    {
      "line": 27,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "今夜は……フィルムの初仕事か。",
      "en": ""
    },
    {
      "line": 53,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "いつもお姉さんぶるフィルムに心配はいらないと思いつつ、<br>心のどこかで彼女のことが気にかかっていた。",
      "en": ""
    },
    {
      "line": 76,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "ノワール……！？",
      "en": ""
    },
    {
      "line": 78,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "フィルムを呪っている幽霊、ノワールが突然に姿を見せた。<br>彼女を離れ、１人で現れるのは珍しいことだった。",
      "en": ""
    },
    {
      "line": 86,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "強い意思のこもった視線に、自然と瞳が吸い寄せられる。<br>ノワールの力なのだろう、脳内に明確なイメージが映し出された。",
      "en": ""
    },
    {
      "line": 118,
      "cmd": "message",
      "field": 2,
      "name": "フィルム<娼館>",
      "jp": "……わたし、これからお客さんと、<br>えっちなことをするのね。",
      "en": ""
    },
    {
      "line": 125,
      "cmd": "message",
      "field": 2,
      "name": "フィルム<娼館>",
      "jp": "娼館のお仕事は大切だって分かっているけど……。<br>せめて初めての人は、好意を持っている人がよかったわ。",
      "en": ""
    },
    {
      "line": 129,
      "cmd": "message",
      "field": 2,
      "name": "フィルム<娼館>",
      "jp": "……司令官くん、が。",
      "en": ""
    },
    {
      "line": 154,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ノワールだけにこぼした、フィルムの本当の気持ち。<br>それをはっきりと見せられた。",
      "en": ""
    },
    {
      "line": 158,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "フィルムの気持ちを知った上で、<br>放っておくことはできなかった。",
      "en": ""
    },
    {
      "line": 183,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "――トントン",
      "en": ""
    },
    {
      "line": 186,
      "cmd": "message",
      "field": 2,
      "name": "フィルム<娼館>",
      "jp": "……お客さんが来たのね。",
      "en": ""
    },
    {
      "line": 203,
      "cmd": "message",
      "field": 2,
      "name": "フィルム<娼館>",
      "jp": "（大丈夫、フィルムお姉さんなら平気よ。<br>このぐらいで悲しむほど、人生経験は少なくないもの）",
      "en": ""
    },
    {
      "line": 230,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "姿を見せた人物に、フィルムが驚きをあらわにする。",
      "en": ""
    },
    {
      "line": 237,
      "cmd": "message",
      "field": 2,
      "name": "フィルム<娼館>",
      "jp": "し、司令官くんっ！？<br>どうしたの？　様子を見に来たの？",
      "en": ""
    },
    {
      "line": 239,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "困惑する彼女に、自分が客であることを告げた。",
      "en": ""
    },
    {
      "line": 245,
      "cmd": "message",
      "field": 2,
      "name": "フィルム<娼館>",
      "jp": "そんな……嘘……。<br>司令官くんが、わたしを……？",
      "en": ""
    },
    {
      "line": 262,
      "cmd": "message",
      "field": 2,
      "name": "フィルム<娼館>",
      "jp": "（初めての人が、司令官くんなら……すごく、嬉しい……！<br>だけど、本当にわたしで、いいの……？）",
      "en": ""
    },
    {
      "line": 279,
      "cmd": "message",
      "field": 2,
      "name": "フィルム<娼館>",
      "jp": "でも、わたしみたいなお婆ちゃんが、<br>司令官くんのお相手だなんて……",
      "en": ""
    },
    {
      "line": 301,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "戸惑うフィルムへと歩み寄る。<br>こちらは客なのだから、相手をしてもらわなければならない。",
      "en": ""
    },
    {
      "line": 303,
      "cmd": "message",
      "field": 2,
      "name": "フィルム<娼館>",
      "jp": "あ……司令官くんっ！？",
      "en": ""
    }
  ]
