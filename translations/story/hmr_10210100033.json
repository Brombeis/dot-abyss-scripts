  "lines": [
    {
      "line": 15,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "うぅ……よく覚えてないんだが……<br>なんだか大変なことをしたような気がする……",
      "en": ""
    },
    {
      "line": 17,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "一足先に浴室に行ったヒュメナの帰りを待ちながら、考え込む。",
      "en": ""
    },
    {
      "line": 19,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "曖昧だが、妙な触手の生き物に変えられた記憶はうっすらあった。<br>それから完全に記憶がなくなり、気づけばヒュメナが白濁液まみれだった。",
      "en": ""
    },
    {
      "line": 21,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "……ウパ、とんでもないことをしてくれたな……",
      "en": ""
    },
    {
      "line": 23,
      "cmd": "message",
      "field": 2,
      "name": "ウパ",
      "jp": "ウ、ウパ～～～……",
      "en": ""
    },
    {
      "line": 25,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ウパは悪戯を見つかった小犬のように焦っている。<br>どう叱ったものかと考えていると――",
      "en": ""
    },
    {
      "line": 35,
      "cmd": "message",
      "field": 2,
      "name": "ヒュメナ",
      "jp": "司令官君、ウパちゃんをあんまり怒らないであげて。",
      "en": ""
    },
    {
      "line": 37,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "そこにシャワーを浴びに行ったヒュメナが戻ってきた。",
      "en": ""
    },
    {
      "line": 39,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "いや、俺はいいんだが。<br>ヒュメナはいいのか？",
      "en": ""
    },
    {
      "line": 42,
      "cmd": "message",
      "field": 2,
      "name": "ヒュメナ",
      "jp": "うん、私は大丈夫。<br>ウパちゃんは私のためにやってくれたんだもん。",
      "en": ""
    },
    {
      "line": 44,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "ヒュメナのために？<br>いったいウパに何を言ったんだ？",
      "en": ""
    },
    {
      "line": 52,
      "cmd": "message",
      "field": 2,
      "name": "ヒュメナ",
      "jp": "それは……司令官君が優しくしてくれるのは嬉しいけど、<br>たまにはもっと激しく求めてきてほしいな……って……",
      "en": ""
    },
    {
      "line": 54,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "なんだそんなことか。<br>それくらい、言えばいつでもしてやるのに。",
      "en": ""
    },
    {
      "line": 62,
      "cmd": "message",
      "field": 2,
      "name": "ヒュメナ",
      "jp": "えっ、そうなの？<br>それじゃあ……今からでも……？",
      "en": ""
    },
    {
      "line": 70,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ヒュメナは急に色っぽい上目遣いになってこちらを見つめてくる。<br>あんな目に合ったというのに、まだ体力が残っているらしい。",
      "en": ""
    },
    {
      "line": 72,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ヒュメナがその気ならば――と腹を括る。",
      "en": ""
    },
    {
      "line": 74,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "ああ、もちろん。",
      "en": ""
    },
    {
      "line": 99,
      "cmd": "message",
      "field": 2,
      "name": "ヒュメナ",
      "jp": "あ……♡",
      "en": ""
    },
    {
      "line": 101,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "嬉しそうなヒュメナをベッドに押し倒していく。<br>シャワーを浴びたばかりのヒュメナを、またたっぷり汚してしまいそうだ。",
      "en": ""
    }
  ]
