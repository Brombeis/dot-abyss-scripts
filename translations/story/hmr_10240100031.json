    },
    {
      "line": 100,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "魔法植物が苦しげに呻く。",
      "en": ""
    },
    {
      "line": 104,
      "cmd": "message",
      "field": 2,
      "name": "",
