  "lines": [
    {
      "line": 19,
      "cmd": "title",
      "field": 1,
      "name": "",
      "jp": "女海賊キャプテン・ルシータ",
      "en": ""
    },
    {
      "line": 28,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ルシータは娼館で働き始めた。<br>ある日、彼女が出勤すると――",
      "en": ""
    },
    {
      "line": 36,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "ルシータさん、早速あなたをご指名のお客様が来てるわよ。",
      "en": ""
    },
    {
      "line": 44,
      "cmd": "message",
      "field": 2,
      "name": "ルシータ",
      "jp": "ホントか？<br>なら、すぐに着替えてくるから、ちょっと待つように言ってくれ。",
      "en": ""
    },
    {
      "line": 51,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "あ、着替えなくていいわ。<br>そのままの格好でお願いできるかしら？",
      "en": ""
    },
    {
      "line": 59,
      "cmd": "message",
      "field": 2,
      "name": "ルシータ",
      "jp": "この格好でか？<br>でも――",
      "en": ""
    },
    {
      "line": 63,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "お客様のご希望なの。<br>部屋で待っているから、そのまま行ってあげて。",
      "en": ""
    },
    {
      "line": 76,
      "cmd": "message",
      "field": 2,
      "name": "ルシータ",
      "jp": "（この格好がいいなんて、変わった客だな。<br>ま、アタシは楽でいいけどさ）",
      "en": ""
    },
    {
      "line": 102,
      "cmd": "message",
      "field": 2,
      "name": "ルシータ",
      "jp": "待たせたな、ルシータだ。<br>アタシを指名してくれて、ありがとうな。",
      "en": ""
    },
    {
      "line": 104,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ルシータの姿を見るなり、客の男は顔を輝かせた。<br>まるで、憧れの人物を前にしたファンのようだ。",
      "en": ""
    },
    {
      "line": 111,
      "cmd": "message",
      "field": 2,
      "name": "ルシータ",
      "jp": "この格好がいいって聞いたんだけど……ホントに構わないのか？",
      "en": ""
    },
    {
      "line": 113,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ルシータの問いに、客は頷き、その理由を説明し始める。",
      "en": ""
    },
    {
      "line": 121,
      "cmd": "message",
      "field": 2,
      "name": "ルシータ",
      "jp": "へぇ、アンタも『キャプテン・ボニー』を知ってるのか！",
      "en": ""
    },
    {
      "line": 123,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "『キャプテン・ボニー』は、女海賊が主人公の物語だ。<br>客は子供の頃にそれを読んで、女海賊に憧れているのだという。",
      "en": ""
    },
    {
      "line": 132,
      "cmd": "message",
      "field": 2,
      "name": "ルシータ",
      "jp": "アンタ、なかなか分かってるじゃないか！<br>気に入ったぞ！",
      "en": ""
    },
    {
      "line": 134,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "海賊の魅力とロマンについて熱く語る客に、ルシータのテンションも上がる。<br>客は続けて、今夜は自分が一番好きなシーンを再現してほしいと頼んできた。",
      "en": ""
    },
    {
      "line": 143,
      "cmd": "message",
      "field": 2,
      "name": "ルシータ",
      "jp": "なるほど、それでこの格好ってわけか！<br>もちろんいいぞ！",
      "en": ""
    },
    {
      "line": 150,
      "cmd": "message",
      "field": 2,
      "name": "ルシータ",
      "jp": "マストの上での決闘シーンか？<br>それとも、ロープを使って敵の船に乗り込むシーンか？",
      "en": ""
    },
    {
      "line": 153,
      "cmd": "message",
      "field": 2,
      "name": "ルシータ",
      "jp": "アンタの希望に、なんでも応えてやるよ！",
      "en": ""
    },
    {
      "line": 155,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ルシータの言葉を聞いて、客はキラリと目を光らせ、こう言った。<br>今、「なんでも」と言いましたね……？",
      "en": ""
    },
    {
      "line": 174,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ビリビリビリッ！",
      "en": ""
    },
    {
      "line": 176,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ジャラジャラジャラッ！",
      "en": ""
    },
    {
      "line": 178,
      "cmd": "message",
      "field": 2,
      "name": "ルシータ",
      "jp": "ちょっ、ちょっと待てーーーっ！？",
      "en": ""
    }
  ]
}
