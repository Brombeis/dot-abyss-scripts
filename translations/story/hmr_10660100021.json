    {
      "line": 68,
      "cmd": "message",
      "field": 2,
      "name": "ヒマリ",
      "jp": "って、このくらいで恥ずかしがってちゃだめ……だよね。<br>しれーかんのために娼館で働くって決めたんだし、頑張らないと……っ。",
      "en": ""
    },
    {
      "line": 77,
      "cmd": "message",
      "field": 2,
      "name": "ヒマリ",
      "jp": "よし……行こう……。<br>お客さん――いるのかな？",
      "en": ""
    },
    {
      "line": 140,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ヒマリが現れると、酒場に集まっていた男たちから<br>わぁっ！　と歓声が上がった。",
      "en": ""
    },
    {
      "line": 150,
      "cmd": "message",
      "field": 2,
