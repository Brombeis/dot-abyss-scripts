  "lines": [
    {
      "line": 18,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "森から娼館に戻ってくるころには、魔法植物はすっかり元に戻っていた。",
      "en": ""
    },
    {
      "line": 20,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "お前、元に戻ったな。",
      "en": ""
    },
    {
      "line": 34,
      "cmd": "message",
      "field": 2,
      "name": "マックン[マニョリア]",
      "jp": "あ～、元に戻っちまったな。<br>けっこう気分良かったのによぉ。",
      "en": ""
    },
    {
      "line": 48,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "魔法植物は残念そうだ。<br>すっかり楽しんでいたらしい。",
      "en": ""
    },
    {
      "line": 50,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "実はルディアに聞いたんだが、<br>娼館の前で咲いていたあの花は、大穴の中で発見された”異物”だったらしい。",
      "en": ""
    },
    {
      "line": 58,
      "cmd": "message",
      "field": 2,
      "name": "マニョリア",
      "jp": "異物？　それって……",
      "en": ""
    },
    {
      "line": 60,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "つまり、別の世界から転移されてきた植物ってことだ。<br>だから、植物に詳しいお前が知らないのも無理はない。",
      "en": ""
    },
    {
      "line": 68,
      "cmd": "message",
      "field": 2,
      "name": "マニョリア",
      "jp": "そっか……。だから初めて見るお花だったんだ。<br>すごく、綺麗なお花で、びっくりしちゃった。",
      "en": ""
    },
    {
      "line": 70,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "マニョリアは異世界から転移されてきた植物に興味津々の様子だ。",
      "en": ""
    },
    {
      "line": 72,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "しかし、ルディアのヤツ、なんであんな危ない花を庭で育ててたんだろうな。<br>まさか、あの花粉で何か企んでるんじゃ……う～ん……",
      "en": ""
    },
    {
      "line": 74,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "いいか？　あの危ない花には２度と近付くんじゃないぞ！<br>特に、その魔法植物を近付けるのだけは厳禁だ！",
      "en": ""
    },
    {
      "line": 76,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "念のため釘をさしておく。<br>すると、マニョリアはヒョコヒョコと体をすり寄せてきた。",
      "en": ""
    },
    {
      "line": 96,
      "cmd": "message",
      "field": 2,
      "name": "マニョリア",
      "jp": "ううん……あのお花、全然危なくなんてないよ……",
      "en": ""
    },
    {
      "line": 98,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "は？　何言ってるんだ？<br>お前、さっきあんなに危ない目に……",
      "en": ""
    },
    {
      "line": 107,
      "cmd": "message",
      "field": 2,
      "name": "マニョリア",
      "jp": "だって、すごく気持ち良かったから……<br>おにいさんも……マックンも……",
      "en": ""
    },
    {
      "line": 110,
      "cmd": "message",
      "field": 2,
      "name": "マニョリア",
      "jp": "……また、みんなでしよう……ね？",
      "en": ""
    },
    {
      "line": 112,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "お、おい、マニョリア！？<br>本気で言ってるのか……！？",
      "en": ""
    },
    {
      "line": 120,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "マニョリアの目は本気のようだ。<br>どうやらあの花粉によるプレイを随分と気に入ってしまったらしい……",
      "en": ""
    }
  ]
}
