  "lines": [
    {
      "line": 19,
      "cmd": "title",
      "field": 1,
      "name": "",
      "jp": "謎多きダリアの噂",
      "en": ""
    },
    {
      "line": 45,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "お、親方。どうして私の部屋に……？",
      "en": ""
    },
    {
      "line": 47,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "用事があって来たんだが……。<br>今はそれどころじゃないな。",
      "en": ""
    },
    {
      "line": 49,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "おい、ダリア。<br>いったいなんなんだ、この大量の鉱石は？",
      "en": ""
    },
    {
      "line": 60,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "あ、え、えっと……",
      "en": ""
    },
    {
      "line": 89,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "…………ぐう……",
      "en": ""
    },
    {
      "line": 91,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "おいおい、ここで寝たふりをするのはさすがに無理があるだろう……",
      "en": ""
    },
    {
      "line": 119,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "は、はいっ。すみません……",
      "en": ""
    },
    {
      "line": 121,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "詳しく説明してもらおうか。<br>こんな量の鉱石、いったいどうしたんだ。",
      "en": ""
    },
    {
      "line": 132,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "……説明……ですか……。<br>その、なんて言ったらいいのか……",
      "en": ""
    },
    {
      "line": 143,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "…………あう……",
      "en": ""
    },
    {
      "line": 145,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "固まるんじゃない。<br>ちゃんと説明するまで逃がさんからな。",
      "en": ""
    },
    {
      "line": 147,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "よく見たら鉱石だけじゃなくて、<br>魔石や宝石まで混ざってるじゃないか。",
      "en": ""
    },
    {
      "line": 149,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "どこから集めてきた。正直に答えろ。",
      "en": ""
    },
    {
      "line": 160,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "……ええと、あの、その……",
      "en": ""
    },
    {
      "line": 169,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "わ、私……宝石が好きなんです。",
      "en": ""
    },
    {
      "line": 171,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "それは前にも聞いた。それで？",
      "en": ""
    },
    {
      "line": 178,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "それで……宝石を探すのが趣味で。<br>大きくてきれいな宝石を見つけられると、すごくうれしくて。",
      "en": ""
    },
    {
      "line": 180,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "そのようだな。それで？",
      "en": ""
    },
    {
      "line": 191,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "それで……つい、宝石探しに没頭しちゃって。<br>気がついたらたくさん掘り出してしまってて。",
      "en": ""
    },
    {
      "line": 193,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "うむ……",
      "en": ""
    },
    {
      "line": 204,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "この前の探索の時も……結局コートのポケットとか、<br>パンツの中までぎゅうぎゅうに詰めて――",
      "en": ""
    },
    {
      "line": 206,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "待て！　いったん止まれ。<br>話がどんどん逸れてるぞ。",
      "en": ""
    },
    {
      "line": 217,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "あっ……そ、そうでしたか？<br>すみません……",
      "en": ""
    },
    {
      "line": 219,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "もう１回聞く。<br>どうして鉱石がこんなにあるんだ。",
      "en": ""
    },
    {
      "line": 230,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "ええと……。<br>いっぱいあったほうが、いいじゃないですか……？",
      "en": ""
    },
    {
      "line": 232,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "それは説明になってない。<br>どうやってこんなに集めてきたのか答えるんだ。",
      "en": ""
    },
    {
      "line": 244,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "それは……一生懸命、頑張って……はい。",
      "en": ""
    },
    {
      "line": 246,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "だからな！？　どこで、どうして、どうやって！<br>集めてきたんだと聞いているのだが！？",
      "en": ""
    },
    {
      "line": 265,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "…………うぅ……",
      "en": ""
    },
    {
      "line": 267,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "……あー……すまん。<br>思わず熱くなった。",
      "en": ""
    },
    {
      "line": 278,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "いえ……私こそ、すみません。<br>上手く答えられなくて……",
      "en": ""
    },
    {
      "line": 280,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "はぁ……。いいか、ダリア。",
      "en": ""
    },
    {
      "line": 282,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "俺がここに来たのは、<br>お前の噂の真偽を確かめるためだ。",
      "en": ""
    },
    {
      "line": 294,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "噂……ですか？",
      "en": ""
    },
    {
      "line": 296,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "あぁ。お前が元々、盗賊団の一味だったという噂があってな。",
      "en": ""
    },
    {
      "line": 307,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "！",
      "en": ""
    },
    {
      "line": 309,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "兵士たちがお前のことを怖がっているようだ。<br>噂のせいで、普段の行動も怪しく見えてしまうとな。",
      "en": ""
    },
    {
      "line": 320,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "そう、なんですか……",
      "en": ""
    },
    {
      "line": 322,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "今は、ただの噂だ。だからこそ確認したい。<br>どうなんだ？",
      "en": ""
    },
    {
      "line": 333,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "…………うぅ……",
      "en": ""
    },
    {
      "line": 364,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "……本当、です。それ……",
      "en": ""
    },
    {
      "line": 366,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "なに……？",
      "en": ""
    },
    {
      "line": 375,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "私、元盗賊です。その噂も、本当のことです……<br>……黙っていてごめんなさい。",
      "en": ""
    },
    {
      "line": 386,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "でも、もう違うんです。<br>盗賊はやめました。今はただの採掘家です。",
      "en": ""
    },
    {
      "line": 397,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "これもぜんぶ、盗んだものじゃありません。<br>本当なんです……",
      "en": ""
    },
    {
      "line": 399,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "むう……なるほど。",
      "en": ""
    },
    {
      "line": 401,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "噂が本当だったのなら……<br>簡単に信じるわけにはいかないな。",
      "en": ""
    },
    {
      "line": 412,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "……そう、ですよね。",
      "en": ""
    },
    {
      "line": 414,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "悪いが、もっと詳しく聞かせてもらう。<br>この鉱石の山について、イチからちゃんと――",
      "en": ""
    },
    {
      "line": 418,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "――ガチャッ",
      "en": ""
    },
    {
      "line": 469,
      "cmd": "message",
      "field": 2,
      "name": "少女",
      "jp": "おねえちゃーん！　遊びに来たよー！",
      "en": ""
    },
    {
      "line": 471,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "！？",
      "en": ""
    },
    {
      "line": 482,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "……っ！！",
      "en": ""
    },
    {
      "line": 493,
      "cmd": "message",
      "field": 2,
      "name": "少女",
      "jp": "あれぇ？　おじさんだぁれ？",
      "en": ""
    },
    {
      "line": 495,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "お、おじさん？<br>おい、誰が――",
      "en": ""
    },
    {
      "line": 542,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "来ちゃだめっ！！",
      "en": ""
    },
    {
      "line": 544,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "！",
      "en": ""
    },
    {
      "line": 555,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "早く、外に出て！　お願い……！",
      "en": ""
    },
    {
      "line": 607,
      "cmd": "message",
      "field": 2,
      "name": "少女",
      "jp": "おねえちゃん……？",
      "en": ""
    },
    {
      "line": 609,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "ふん。悪いが……",
      "en": ""
    },
    {
      "line": 656,
      "cmd": "message",
      "field": 2,
      "name": "少女",
      "jp": "きゃあっ！？",
      "en": ""
    },
    {
      "line": 658,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "何も聞かずに、逃がすわけにはいかないな。",
      "en": ""
    },
    {
      "line": 698,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "……！",
      "en": ""
    }
  ]
