  "lines": [
    {
      "line": 16,
      "cmd": "title",
      "field": 1,
      "name": "",
      "jp": "口下手彼女の素直な気持ち",
      "en": ""
    },
    {
      "line": 27,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "――夜。<br>司令室で仕事をしていると突然、ノックの音が響いた。",
      "en": ""
    },
    {
      "line": 29,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "ん？<br>入っていいぞ。",
      "en": ""
    },
    {
      "line": 47,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "……こんばんは、親方。",
      "en": ""
    },
    {
      "line": 50,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "ダリアか。どうしたんだこんな時間に。<br>それに、その格好は――",
      "en": ""
    },
    {
      "line": 76,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "な、なんだっ？　急に抱き着いてきたりして！？",
      "en": ""
    },
    {
      "line": 90,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "お礼したくて……色々教えてもらいに来たんです……。<br>うまくできないかもだけど、よろしくお願いします。ではまずはキスから――",
      "en": ""
    },
    {
      "line": 93,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "ちょ、ちょっと待て～～っ！！",
      "en": ""
    },
    {
      "line": 110,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "――なるほど。要は先日、俺の世話になったから<br>恩返しがしたくてここへ来た――というわけか。",
      "en": ""
    },
    {
      "line": 119,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "はい……最初にそう言ったつもりだったのですが……",
      "en": ""
    },
    {
      "line": 132,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "（言ってないだろ……やっぱり口下手だな……<br>それにあの時も、恩義を感じている様子はなかったんだがなぁ）",
      "en": ""
    },
    {
      "line": 153,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "私、親方の役に立ちたいから娼館で働きます。<br>……衣装も揃えてきました。",
      "en": ""
    },
    {
      "line": 156,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "気持ちはありがたいが、そこまでしなくていいぞ。<br>大穴探索で力を貸してくれたら十分だ。",
      "en": ""
    },
    {
      "line": 177,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ダリアはふるふると首を横に振って、無言で、静かに抱き着いてくる。",
      "en": ""
    },
    {
      "line": 187,
      "cmd": "message",
      "field": 2,
      "name": "ダリア",
      "jp": "研修……してください……",
      "en": ""
    },
    {
      "line": 201,
      "cmd": "message",
      "field": 2,
      "name": "<user>",
      "jp": "（研修って……まあそれは説明されずとも分かるが……<br>もしかしてこいつ、俺のことが……？）",
      "en": ""
    },
    {
      "line": 214,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "確信は得られないが、女性に恥をかかせるものではない――。<br>そうしてダリアの手を引き、娼館へ移動するのだった。",
      "en": ""
    }
  ]
}