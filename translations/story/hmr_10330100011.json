  "lines": [
    {
      "line": 19,
      "cmd": "title",
      "field": 1,
      "name": "",
      "jp": "絶対絶命のエメルダ",
      "en": ""
    },
    {
      "line": 30,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "――その日、エメルダは特ダネを求めて酒場に張っていた。",
      "en": ""
    },
    {
      "line": 42,
      "cmd": "message",
      "field": 2,
      "name": "エメルダ",
      "jp": "（クソ上司めぇえ……<br>『さっさと特ダネ持ってこい！』とか気軽に言いやがって～！）",
      "en": ""
    },
    {
      "line": 50,
      "cmd": "message",
      "field": 2,
      "name": "エメルダ",
      "jp": "（どうせほしいのは前線基地の醜聞でしょ！<br>えぇ、えぇ、いいわよ、やってやろうじゃん）",
      "en": ""
    },
    {
      "line": 59,
      "cmd": "message",
      "field": 2,
      "name": "エメルダ",
      "jp": "（ここの酒場の２階……娼館に特ダネさんが頻繁に通ってるわ！）",
      "en": ""
    },
    {
      "line": 68,
      "cmd": "message",
      "field": 2,
      "name": "エメルダ",
      "jp": "（きっと複数の娼婦を抱えて悪いことしてるんでしょ！<br>知らんけど！）",
      "en": ""
    },
    {
      "line": 77,
      "cmd": "message",
      "field": 2,
      "name": "エメルダ",
      "jp": "（しばらくは客のふりして普通に飲んで――隙を見て２階の部屋に<br>潜り込んじゃうもんね～。特ダネさん、活きのいいネタ、頼みますよー！）",
      "en": ""
    },
    {
      "line": 101,
      "cmd": "message",
      "field": 2,
      "name": "エメルダ",
      "jp": "（よしっ、潜入成功♪<br>思ったより簡単だったなぁ。ザル警備、助かる～っ♪）",
      "en": ""
    },
    {
      "line": 111,
      "cmd": "message",
      "field": 2,
      "name": "エメルダ",
      "jp": "（あとは、特ダネさんが入った部屋の様子をどうにかして――）",
      "en": ""
    },
    {
      "line": 121,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "ふふふっ。だめですよーっ。<br>そぉーれっ♪",
      "en": ""
    },
    {
      "line": 132,
      "cmd": "message",
      "field": 2,
      "name": "エメルダ",
      "jp": "はい！？",
      "en": ""
    },
    {
      "line": 154,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "エメルダの背後に現れたルディアが、<br>ぷしゅーっ、と香水を振り掛ける。眠り薬入りの香水だ。",
      "en": ""
    },
    {
      "line": 156,
      "cmd": "message",
      "field": 2,
      "name": "エメルダ",
      "jp": "はにゃぁっ…………ぐーっ。",
      "en": ""
    },
    {
      "line": 187,
      "cmd": "message",
      "field": 2,
      "name": "ルディア",
      "jp": "ふふっ、悪い子にはお仕置きしないとですねー。<br>さて、あの方を呼んできましょうか♪",
      "en": ""
    },
    {
      "line": 208,
      "cmd": "message",
      "field": 2,
      "name": "エメルダ",
      "jp": "う、う～ん……あれ、あたし、寝て……？",
      "en": ""
    },
    {
      "line": 210,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "目が覚めると、エメルダは真っ暗な部屋の中にいた。<br>……と思ったのだが、すぐに違うことに気付く。",
      "en": ""
    },
    {
      "line": 216,
      "cmd": "message",
      "field": 2,
      "name": "エメルダ",
      "jp": "（違う！　これ、目隠しだ！？　しかも縛られてる！？<br>おまけに裸じゃん！　なにこれぇ～！？　服どこー！？）",
      "en": ""
    },
    {
      "line": 228,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "暴れて逃れようとするが、身動きは取れない。<br>じたばたしているうちに、誰かが室内に入ってくる気配がした。",
      "en": ""
    }
  ]
}
