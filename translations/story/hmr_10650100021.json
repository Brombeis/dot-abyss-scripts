  "lines": [
    {
      "line": 17,
      "cmd": "title",
      "field": 1,
      "name": "",
      "jp": "タイトル",
      "en": ""
    },
    {
      "line": 51,
      "cmd": "message",
      "field": 2,
      "name": "ソフィア",
      "jp": "雰囲気のある内装に、薄暗い照明。大きなベッド……。<br>ここでお客さんとエッチなことをするのね……",
      "en": ""
    },
    {
      "line": 103,
      "cmd": "message",
      "field": 2,
      "name": "ソフィア",
      "jp": "（はぁ……、いくら人手が足りないとはいえ、<br>こんな慣れない仕事、引き受けるんじゃなかったかなぁ……）",
      "en": ""
    },
    {
      "line": 120,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "イスに腰掛けたソフィアは、ドキドキと心臓を高鳴らせ、<br>初めての客が訪れるのを待っていた。",
      "en": ""
    },
    {
      "line": 147,
      "cmd": "message",
      "field": 2,
      "name": "ソフィア",
      "jp": "（ここで待っていればお客さんが来るって、<br>ルディアさんは言っていたけれど……）",
      "en": ""
    },
    {
      "line": 158,
      "cmd": "message",
      "field": 2,
      "name": "ソフィア",
      "jp": "（いったいどんな人が来るのかしら……。<br>まさかベテランのおじさまに、すごいことをされてしまう、とか……？）",
      "en": ""
    },
    {
      "line": 169,
      "cmd": "message",
      "field": 2,
      "name": "ソフィア",
      "jp": "（……ま、まだなのかしら？　うぅ……早く来てよ～っ……。<br>待っている時間が長ければ長いほど、緊張しちゃうわ……）",
      "en": ""
    },
    {
      "line": 210,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "――コンコン、と扉をノックする音が響く。",
      "en": ""
    },
    {
      "line": 221,
      "cmd": "message",
      "field": 2,
      "name": "ソフィア",
      "jp": "ひゃいっ！？",
      "en": ""
    },
    {
      "line": 242,
      "cmd": "message",
      "field": 2,
      "name": "ソフィア",
      "jp": "（あっ！　へ、変な声が出ちゃった！<br>お仕事なんだから、ちゃんとしないと……！）",
      "en": ""
    },
    {
      "line": 270,
      "cmd": "message",
      "field": 2,
      "name": "ソフィア",
      "jp": "ど、どうぞ……",
      "en": ""
    },
    {
      "line": 272,
      "cmd": "message",
      "field": 2,
      "name": "？？？",
      "jp": "ししし失礼します！",
      "en": ""
    },
    {
      "line": 278,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "部屋に入ってきたのはまだ年若い兵士だった。<br>見るからに緊張して、ガチガチに固まっている。",
      "en": ""
    },
    {
      "line": 280,
      "cmd": "message",
      "field": 2,
      "name": "客の青年",
      "jp": "その、ここのお世話になるのは初めてで……<br>よろしくお願いいたしますっ！！！",
      "en": ""
    },
    {
      "line": 316,
      "cmd": "message",
      "field": 2,
      "name": "ソフィア",
      "jp": "そ、そうなの？<br>こちらこそよろしくね……",
      "en": ""
    },
    {
      "line": 343,
      "cmd": "message",
      "field": 2,
      "name": "ソフィア",
      "jp": "（すごく緊張してるみたい……なんだか可哀想。<br>私が慌てている場合じゃないわね――しっかりしないとっ）",
      "en": ""
    },
    {
      "line": 371,
      "cmd": "message",
      "field": 2,
      "name": "ソフィア",
      "jp": "大丈夫、きっと楽しませてみせるから。<br>私に任せて、ね？",
      "en": ""
    },
    {
      "line": 373,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "ソフィアは決意の表情で、<br>ゆっくりと男の手を引くのだった――",
      "en": ""
    }
  ]
}
