  "lines": [
    {
      "line": 37,
      "cmd": "message",
      "field": 2,
      "name": "マリナ",
      "jp": "今日は、ありがとうございました！<br>良かったらまた指名してくださいねっ！",
      "en": ""
    },
    {
      "line": 39,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "接客を終えたマリナは、客の男を店の入り口まで見送る。",
      "en": ""
    },
    {
      "line": 41,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "――マリナさんの身体から出たポーションのおかげで、元気になりました！<br>帰り際、男はそう言って笑顔見せる。",
      "en": ""
    },
    {
      "line": 52,
      "cmd": "message",
      "field": 2,
      "name": "マリナ",
      "jp": "ぬはぁっ！　ちょ、ちょっと……恥ずかしいこと言わないでくださいよっ！<br>私の身体から出たポーションって、もぅぅ～……",
      "en": ""
    },
    {
      "line": 54,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "男はまた指名します！　と、約束し笑顔で店を出ていく。<br>その表情は、昼間ポーションを買って帰る時と同じ様子だった。",
      "en": ""
    },
    {
      "line": 103,
      "cmd": "message",
      "field": 2,
      "name": "マリナ",
      "jp": "（わたしのエッチなお汁ってそんなに商品価値があるんでしょうかぁ？<br>だとしたらこれを売り出せば大儲けできたり……）",
      "en": ""
    },
    {
      "line": 114,
      "cmd": "message",
      "field": 2,
      "name": "マリナ",
      "jp": "（って、ダメダメ！<br>そんな商品、恥ずかしくて売りだせるわけないって！）",
      "en": ""
    },
    {
      "line": 131,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "マリナは一瞬、商売っ気がよぎるが、慌ててそれを掻き消す。",
      "en": ""
    },
    {
      "line": 157,
      "cmd": "message",
      "field": 2,
      "name": "マリナ",
      "jp": "（はぁ……。<br>でもお客さまの前でオナニーするなんて恥ずかしかったなぁ……）",
      "en": ""
    },
    {
      "line": 174,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "マリナはふと、先ほどの客との羞恥プレイを思い出して顔を赤らめる。",
      "en": ""
    },
    {
      "line": 185,
      "cmd": "message",
      "field": 2,
      "name": "マリナ",
      "jp": "（しかも、オナニーしてる時、<br>わたし旦那さまのこと思い浮かべちゃってたし……）",
      "en": ""
    },
    {
      "line": 212,
      "cmd": "message",
      "field": 2,
      "name": "マリナ",
      "jp": "旦那さまに会いたいですねぇ～……",
      "en": ""
    },
    {
      "line": 214,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "無意識に、ぽつりとこぼれた言葉。<br>溢れ出した本音に、マリナはコクリと大きく頷く。",
      "en": ""
    },
    {
      "line": 226,
      "cmd": "message",
      "field": 2,
      "name": "マリナ",
      "jp": "ルディアさんにお願いして、今日は早退させてもらいましょうかぁ♪ <br>そして、旦那さまに会いに……",
      "en": ""
    },
    {
      "line": 277,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "マリナは、内から溢れ出す感情の奔流に身を任せることに決めた。<br>彼女にとって今、何が本当に大切なのかは明白だった。",
      "en": ""
    },
    {
      "line": 288,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "金銭でも、希少な鉱石でもない。<br>この瞬間、マリナにとって最も価値あるもの――",
      "en": ""
    },
    {
      "line": 292,
      "cmd": "message",
      "field": 2,
      "name": "",
      "jp": "その答えに向かって、マリナは静かに歩み始めた。",
      "en": ""
    }
  ]
}